# OpenAI-compatible LLM config
PMMA_LLM_ENABLED=1
PMMA_LLM_BASE_URL=https://api.deepseek.com
PMMA_LLM_API_KEY=your-deepseek-api-key
PMMA_LLM_MODEL=deepseek-chat
PMMA_LLM_PROVIDER=deepseek

# Optional copywriter enhancement
PMMA_LLM_COPYWRITER_ENABLED=1

# Optional runtime config
# PMMA_LLM_TIMEOUT=30
# PMMA_LLM_API_PATH=/chat/completions
